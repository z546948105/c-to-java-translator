#include <stdio.h>      // 标准输入输出
#include <stdlib.h>     // 动态内存分配、通用工具
#include <string.h>     // 字符串处理
#include <stdarg.h>     // 可变参数支持
#include <math.h>       // 数学库

// 1. 宏定义与条件编译
#define MAX_SIZE 100
#define SQUARE(x) ((x) * (x))
#ifdef DEBUG
    #define LOG(msg) printf("[DEBUG] %s\n", msg)
#else
    #define LOG(msg)
#endif

// 2. 枚举类型
typedef enum { RED, GREEN, BLUE } Color;

// 3. 结构体与位域
typedef struct {
    unsigned int age : 7;      // 位域：仅占7个bit
    Color favorite_color;
    char name[50];
} Person;

// 4. 联合体 (Union)
typedef union {
    int i;
    float f;
    char str[20];
} Data;

// 5. 函数指针类型定义
typedef int (*MathOp)(int, int);

// 6. 普通函数与可变参数
int sum(int count, ...) {
    int total = 0;
    va_list args;
    va_start(args, count);
    for (int i = 0; i < count; i++) {
        total += va_arg(args, int);
    }
    va_end(args);
    return total;
}

int add(int a, int b) { return a + b; }
int sub(int a, int b) { return a - b; }

int main() {
    // 7. 基础数据类型与类型转换
    int a = 10;
    double b = 3.14;
    char c = 'A';
    long long big_num = 9999999999LL;
    unsigned int u = 100U;
    double result = (double)a / 3; // 显式类型转换 (Cast)

    // 8. 指针与地址操作
    int *ptr = &a;
    *ptr = 20; // 解引用修改值
    void *generic_ptr = ptr; // 通用指针

    // 9. 数组与字符串
    int arr[5] = {1, 2, 3, 4, 5};
    char str[] = "Hello, C!";
    char *str_ptr = "Pointer String";

    // 10. 结构体与联合体使用
    Person p = {25, GREEN, "Alice"};
    Data data;
    data.i = 100;
    data.f = 22.5; // 会覆盖 data.i 的值

    // 11. 位运算
    unsigned int flags = 0b00001010;
    flags |= (1 << 2);  // 置位
    flags &= ~(1 << 1); // 清位
    flags ^= (1 << 3);  // 翻转位

    // 12. 函数指针与回调
    MathOp operation = add;
    printf("10 + 5 = %d\n", operation(10, 5));
    operation = sub;
    printf("10 - 5 = %d\n", operation(10, 5));

    // 13. 动态内存分配
    int *dyn_arr = (int *)malloc(MAX_SIZE * sizeof(int));
    if (dyn_arr == NULL) return 1; // 内存分配失败检查
    dyn_arr[0] = 99;
    free(dyn_arr); // 释放内存，防止泄漏

    // 14. 控制流语句
    // 条件分支
    if (a > 10) {
        printf("a is large\n");
    } else if (a == 10) {
        printf("a is 10\n");
    } else {
        printf("a is small\n");
    }

    // Switch-case
    switch (p.favorite_color) {
        case RED: printf("Color is Red\n"); break;
        case GREEN: printf("Color is Green\n"); break;
        default: printf("Unknown color\n"); break;
    }

    // 循环
    for (int i = 0; i < 5; i++) { /* 遍历数组 */ }
    int j = 0;
    while (j < 5) { j++; }
    do { j--; } while (j > 0);

    // 15. 宏与数学库调用
    printf("Square of 5: %d\n", SQUARE(5));
    printf("Pi: %.2f\n", M_PI);

    // 16. 可变参数调用
    printf("Sum: %d\n", sum(4, 10, 20, 30, 40));

    // 17. 文件I/O操作
    FILE *fp = fopen("test.txt", "w");
    if (fp) {
        fprintf(fp, "Writing to file: %s\n", str);
        fclose(fp);
    }

    LOG("Program finished successfully.");
    return 0;
}